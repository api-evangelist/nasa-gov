    "_postman_id": "ec67f5ae-fce9-481d-a225-758f079b72bd",
    "name": "NASA Astronomy Picture of the Day (APOD) API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": {
      "content": "One of the most popular NASA websites, exposed as a JSON API. Returns the Astronomy Picture of the Day with\ntitle, explanation, image URL, HD URL, optional copyright, and media type. Supports single date, date ranges,\nrandom counts, and video thumbnails.\n\n\nContact Support:\n Name: NASA Open APIs",
      "type": "text/plain"
    }

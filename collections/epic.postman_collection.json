  "info": {
    "_postman_id": "1516dea7-d0e2-4738-98e9-e631d30c717d",
    "name": "NASA EPIC (Earth Polychromatic Imaging Camera) API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": {
      "content": "The DSCOVR EPIC instrument provides full-disc imagery of Earth and captures unique perspectives of certain\nastronomical events such as lunar transits. The API returns natural and enhanced color image metadata with\ncentroid coordinates, spacecraft, sun, and lunar positions.\n\n\nContact Support:\n Name: NASA EPIC",
      "type": "text/plain"
    }
  }

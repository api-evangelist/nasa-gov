{
  "opencollection": "1.0.0",
  "info": {
    "name": "NASA TechPort API",
    "version": "1.0"
  },
  "request": {
    "auth": {
      "type": "apikey",
      "key": "api_key",
      "value": "{{api_key}}",
      "placement": "query"
    }
  },
  "items": [
    {
      "info": {
        "name": "Projects",
        "type": "folder"
      },
      "items": [
        {
          "info": {
            "name": "List TechPort Projects",
            "type": "http"
          },
          "http": {
            "method": "GET",
            "url": "https://api.nasa.gov/techport/api/projects",
            "params": [
              {
                "name": "updatedSince",
                "value": "",
                "type": "query"
              },
              {
                "name": "api_key",
                "value": "",
                "type": "query"
              }
            ]
          },
          "docs": "List TechPort Projects"
        },
        {
          "info": {
            "name": "Get TechPort Project by ID",
            "type": "http"
          },
          "http": {
            "method": "GET",
            "url": "https://api.nasa.gov/techport/api/projects/:id",
            "params": [
              {
                "name": "id",
                "value": "",
                "type": "path"
              },
              {
                "name": "api_key",
                "value": "",
                "type": "query"
              }
            ]
          },
          "docs": "Get TechPort Project by ID"
        }
      ]
    }
  ],
  "bundled": true
}
{
  "opencollection": "1.0.0",
  "info": {
    "name": "NASA TechTransfer API",
    "version": "1.0"
  },
  "request": {
    "auth": {
      "type": "apikey",
      "key": "api_key",
      "value": "{{api_key}}",
      "placement": "query"
    }
  },
  "items": [
    {
      "info": {
        "name": "Patents",
        "type": "folder"
      },
      "items": [
        {
          "info": {
            "name": "Search NASA Patents",
            "type": "http"
          },
          "http": {
            "method": "GET",
            "url": "https://api.nasa.gov/techtransfer/patent",
            "params": [
              {
                "name": "patent",
                "value": "",
                "type": "query",
                "description": "Search term to match against patent metadata."
              },
              {
                "name": "api_key",
                "value": "",
                "type": "query"
              }
            ]
          },
          "docs": "Search NASA Patents"
        },
        {
          "info": {
            "name": "Search Issued NASA Patents",
            "type": "http"
          },
          "http": {
            "method": "GET",
            "url": "https://api.nasa.gov/techtransfer/patent/issued",
            "params": [
              {
                "name": "patent_issued",
                "value": "",
                "type": "query"
              },
              {
                "name": "api_key",
                "value": "",
                "type": "query"
              }
            ]
          },
          "docs": "Search Issued NASA Patents"
        }
      ]
    },
    {
      "info": {
        "name": "Software",
        "type": "folder"
      },
      "items": [
        {
          "info": {
            "name": "Search NASA Software",
            "type": "http"
          },
          "http": {
            "method": "GET",
            "url": "https://api.nasa.gov/techtransfer/software",
            "params": [
              {
                "name": "software",
                "value": "",
                "type": "query"
              },
              {
                "name": "api_key",
                "value": "",
                "type": "query"
              }
            ]
          },
          "docs": "Search NASA Software"
        }
      ]
    },
    {
      "info": {
        "name": "Spinoff",
        "type": "folder"
      },
      "items": [
        {
          "info": {
            "name": "Search NASA Spinoff Publications",
            "type": "http"
          },
          "http": {
            "method": "GET",
            "url": "https://api.nasa.gov/techtransfer/spinoff",
            "params": [
              {
                "name": "Spinoff",
                "value": "",
                "type": "query"
              },
              {
                "name": "api_key",
                "value": "",
                "type": "query"
              }
            ]
          },
          "docs": "Search NASA Spinoff Publications"
        }
      ]
    }
  ],
  "bundled": true
}
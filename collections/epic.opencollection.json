          "info": {
            "name": "Get Enhanced Color Images by Date",
            "type": "http"
          },
          "http": {
            "method": "GET",
            "url": "https://api.nasa.gov/EPIC/api/enhanced/date/:date",
            "params": [
              {
                "name": "date",
                "value": "",
                "type": "path"
              },
              {
                "name": "api_key",
                "value": "",
                "type": "query"
              }
            ]
          },
          "docs": "Get Enhanced Color Images by Date"

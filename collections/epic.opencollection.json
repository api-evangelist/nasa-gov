        {
          "info": {
            "name": "Get All Natural Color Image Dates",
            "type": "http"
          },
          "http": {
            "method": "GET",
            "url": "https://api.nasa.gov/EPIC/api/natural/all",
            "params": [
              {
                "name": "api_key",
                "value": "",
                "type": "query"
              }
            ]
          },
          "docs": "Get All Natural Color Image Dates"
        }
      ]
    },
    {
      "info": {
        "name": "Enhanced",
        "type": "folder"
      },
      "items": [
        {
          "info": {
            "name": "Get Most Recent Enhanced Color Images",
            "type": "http"
          },
          "http": {
            "method": "GET",
            "url": "https://api.nasa.gov/EPIC/api/enhanced",
            "params": [

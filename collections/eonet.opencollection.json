                "description": "Filter by source ID (comma-separated for multiple)."
              },
              {
                "name": "status",
                "value": "",
                "type": "query"
              },
              {
                "name": "limit",
                "value": "",
                "type": "query"
              },
              {
                "name": "days",
                "value": "",
                "type": "query",
                "description": "Limit to events within the last N days."
              },
              {
                "name": "start",
                "value": "",
                "type": "query"
              },
              {
                "name": "end",
                "value": "",
                "type": "query"
              },
              {
                "name": "magID",
                "value": "",
                "type": "query"
              },
              {
                "name": "magMin",
                "value": "",
                "type": "query"
              },
              {
                "name": "magMax",
                "value": "",
                "type": "query"
              },
              {
                "name": "bbox",
                "value": "",
                "type": "query",
                "description": "Bounding box minlon,maxlat,maxlon,minlat."
              },
              {
                "name": "category",
                "value": "",
                "type": "query"
              }
            ]
          },
          "docs": "Get Natural Events"
        }
      ]
    },
